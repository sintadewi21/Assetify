{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint \"{resources/js,tests/js}/**/*.js\"",
        "format": "prettier --write \"{resources/js,tests/js}/**/*.js\"",
        "format:check": "prettier --check \"{resources/js,tests/js}/**/*.js\"",
        "test": "jest",
        "prepare": "cd .. && husky inventory-app/.husky"
    },
    "devDependencies": {
        "@babel/core": "^8.0.1",
        "@babel/preset-env": "^8.0.2",
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "babel-jest": "^30.4.1",
        "concurrently": "^9.0.1",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "laravel-vite-plugin": "^2.0.0",
        "lint-staged": "^17.0.8",
        "postcss": "^8.4.31",
        "prettier": "^3.9.4",
        "tailwindcss": "^3.1.0",
        "vite": "^7.0.7"
    },
    "lint-staged": {
        "{resources/js,tests/js}/**/*.js": [
            "eslint --fix",
            "prettier --write"
        ]
    }
}
